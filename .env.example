# Copia este archivo a .env y ajusta los valores en producción.

# PostgreSQL
DB_NAME=stitch
DB_USER=stitch
DB_PASSWORD=cambia-esta-clave

# MinIO  (usuario/clave de administrador)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=cambia-esta-clave-tambien

# Caché (segundos que viven las entradas en Redis)
CACHE_TTL=60
